# ============================================================
# Wootchat CRM — variáveis de ambiente para produção
# Copie este arquivo para `.env` ao subir o stack no Portainer
# (NÃO comite o .env real — só este .example).
# ============================================================

# ──────────────────────────────────────────────────────────
# Banco PostgreSQL (a base precisa existir + ser acessível pela rede OrionNet)
# ──────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres-host:5432/crm_db
SPRING_DATASOURCE_USERNAME=crm_user
SPRING_DATASOURCE_PASSWORD=TROQUE_POR_SENHA_FORTE

# ──────────────────────────────────────────────────────────
# Redis (cache + filas WebSocket + cache de QR Code do WhatsApp)
# ──────────────────────────────────────────────────────────
SPRING_REDIS_HOST=redis-host
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=

# ──────────────────────────────────────────────────────────
# Segurança
# ──────────────────────────────────────────────────────────
# JWT: gere com `openssl rand -base64 64`
JWT_SECRET=GERE_UMA_CHAVE_BASE64_DE_64_BYTES_AQUI
# AES-256 para criptografar credenciais de WhatsApp:
#   openssl rand -hex 32
ENCRYPTION_KEY=GERE_UMA_CHAVE_HEX_DE_32_BYTES_AQUI

# ──────────────────────────────────────────────────────────
# Evolution Go (WhatsApp Gateway)
# ──────────────────────────────────────────────────────────
EVOLUTION_BASE_URL=https://evogo.wootchat.com.br
EVOLUTION_API_KEY=COLE_A_API_KEY_GLOBAL_DO_EVOLUTION_GO

# ──────────────────────────────────────────────────────────
# Frontend ↔ Backend (CORS + URLs públicas)
# ──────────────────────────────────────────────────────────
# Para múltiplas origens, separe por vírgula sem espaços
ALLOWED_ORIGINS=https://chatcrm.wootchat.com.br
# URL pública que o Evolution Go vai chamar nos webhooks (sem barra no final)
WEBHOOK_BASE_URL=https://api.wootchat.com.br/api

# URLs públicas que o navegador do usuário usa
API_BASE_URL=https://api.wootchat.com.br/api
WS_URL=https://api.wootchat.com.br/api/ws

# ──────────────────────────────────────────────────────────
# JVM tuning (opcional)
# ──────────────────────────────────────────────────────────
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0
