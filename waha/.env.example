# ============================================================
# WAHA — variáveis de ambiente
# Copie para `.env` ao subir o stack no Portainer (não comite o real)
# ============================================================

# ──────────────────────────────────────────────────────────
# Imagem (Core gratuito ou Plus pago)
# ──────────────────────────────────────────────────────────
# devlikeapro/waha:latest        → Core (gratuito, recursos básicos)
# devlikeapro/waha-plus:latest   → Plus (pago, +recursos: story, channels, multi-device avançado)
WAHA_IMAGE=devlikeapro/waha:latest

# ──────────────────────────────────────────────────────────
# Autenticação (OBRIGATÓRIO)
# ──────────────────────────────────────────────────────────
# X-Api-Key usada em todas as chamadas. Gere com: openssl rand -hex 24
WHATSAPP_API_KEY=COLE_AQUI_UMA_CHAVE_HEX_GERADA

# Login do dashboard (Swagger UI em https://waha.wootchat.com.br)
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=TROQUE_POR_SENHA_FORTE

# ──────────────────────────────────────────────────────────
# Persistência / arquivos
# ──────────────────────────────────────────────────────────
# Tempo (segundos) que arquivos enviados/recebidos ficam no disco antes de expirarem
WHATSAPP_FILES_LIFETIME=86400

# ──────────────────────────────────────────────────────────
# Comportamento
# ──────────────────────────────────────────────────────────
# false = não imprime QR no log do container (pegamos via API no CRM)
WAHA_PRINT_QR=false
# Delay (ms) entre tentativas de restart de sessões em FAILED
WHATSAPP_RESTART_DELAY=5000
# Quantas vezes o WAHA tenta entregar um webhook antes de desistir
WHATSAPP_HOOK_RETRIES=3
# Engine padrão (WEBJS = whatsapp-web.js; NOWEB no Plus para multi-device avançado)
WHATSAPP_DEFAULT_ENGINE=WEBJS

# ──────────────────────────────────────────────────────────
# Webhook global (DEIXE VAZIO!)
# ──────────────────────────────────────────────────────────
# O Wootchat CRM configura webhook por sessão automaticamente ao criar a
# conexão. Manter estes vazios evita duplicar eventos.
WHATSAPP_HOOK_URL=
WHATSAPP_HOOK_EVENTS=
