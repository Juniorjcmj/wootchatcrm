# ══════════════════════════════════════════════════════════════
# .env.example — Copie para .env e preencha os valores
# NUNCA commite o .env real no Git
# ══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# SPRING
# ─────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# ─────────────────────────────────────────────────────────────
# BANCO DE DADOS
# ─────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/crmdb
SPRING_DATASOURCE_USERNAME=crm_user
SPRING_DATASOURCE_PASSWORD=TROQUE_POR_SENHA_FORTE

# ─────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=
SPRING_REDIS_SSL=false

# ─────────────────────────────────────────────────────────────
# SEGURANÇA
# ─────────────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 64
JWT_SECRET=GERE_UMA_CHAVE_ALEATORIA_DE_64_BYTES_AQUI

# Gerar com: openssl rand -base64 32
ENCRYPTION_KEY=GERE_UMA_CHAVE_AES256_DE_32_BYTES

# ─────────────────────────────────────────────────────────────
# CORS / FRONTEND
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.seucrm.com.br

# ─────────────────────────────────────────────────────────────
# WEBHOOKS
# ─────────────────────────────────────────────────────────────
WEBHOOK_BASE_URL=https://api.seucrm.com.br/api
