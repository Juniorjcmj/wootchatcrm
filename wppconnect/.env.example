# ============================================================
# WPPConnect Server — variáveis de ambiente
# Copie para `.env` ao subir o stack no Portainer (não comite o real)
# ============================================================

# ──────────────────────────────────────────────────────────
# Build
# ──────────────────────────────────────────────────────────
# Branch ou tag do wppconnect-server (https://github.com/wppconnect-team/wppconnect-server)
# que o Docker vai clonar e buildar. Use uma tag (ex.: v2.10.0) pra fixar versão.
WPP_REF=v2.10.0

# ──────────────────────────────────────────────────────────
# Autenticação (OBRIGATÓRIO)
# ──────────────────────────────────────────────────────────
# Esta chave é usada (apenas uma vez por sessão) para gerar o Bearer token.
# No CRM, este mesmo valor vai no campo "SECRET_KEY" ao criar a conexão.
# Gere com:  openssl rand -hex 32
SECRET_KEY=COLE_AQUI_UMA_CHAVE_HEX_GERADA

# ──────────────────────────────────────────────────────────
# Identidade / Endpoint
# ──────────────────────────────────────────────────────────
# Nome do "dispositivo" exibido em Aparelhos conectados do WhatsApp
DEVICE_NAME=Wootchat CRM

# URL pública (ajuste pro seu domínio — não use localhost em prod)
WPP_HOST=https://wppconnect.wootchat.com.br
WPP_PORT=21465

# ──────────────────────────────────────────────────────────
# Performance
# ──────────────────────────────────────────────────────────
# Heap do Node. 2GB cobre ~3-4 sessões simultâneas (1 Chromium por sessão).
NODE_OPTIONS=--max-old-space-size=2048
