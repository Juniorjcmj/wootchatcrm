# ============================================================
# WPPConnect Server — variáveis de ambiente
# Copie para `.env` ao subir o stack no Portainer (não comite o real)
# ============================================================

# ──────────────────────────────────────────────────────────
# Imagem
# ──────────────────────────────────────────────────────────
WPP_IMAGE=wppconnect/wppconnect-server:latest

# ──────────────────────────────────────────────────────────
# Autenticação (OBRIGATÓRIO)
# ──────────────────────────────────────────────────────────
# SECRET_KEY é usada (apenas uma vez por sessão) para gerar o Bearer token.
# No CRM, este mesmo valor vai no campo "SECRET_KEY" ao criar a conexão.
# Gere com:  openssl rand -hex 32
SECRET_KEY=COLE_AQUI_UMA_CHAVE_HEX_GERADA

# ──────────────────────────────────────────────────────────
# Identidade
# ──────────────────────────────────────────────────────────
# Nome do "dispositivo" exibido nos Aparelhos conectados do WhatsApp
DEVICE_NAME=Wootchat CRM

# ──────────────────────────────────────────────────────────
# Engine / Comportamento
# ──────────────────────────────────────────────────────────
# WPPCONNECT (padrão) ou VENOM (fork antigo). Mantenha WPPCONNECT.
ENGINE=WPPCONNECT

# Headless do Puppeteer (Chromium). Sempre true em servidor.
HEADLESS=true

# Auto-fecha sessões inativas após X minutos. 0 = nunca
AUTO_CLOSE=0

# Idioma padrão pro Chromium
DEFAULT_LANG=pt_BR

# ──────────────────────────────────────────────────────────
# Performance
# ──────────────────────────────────────────────────────────
# Heap do Node em MB. 2GB cobre ~5 sessões simultâneas no Chromium.
NODE_OPTIONS=--max-old-space-size=2048
